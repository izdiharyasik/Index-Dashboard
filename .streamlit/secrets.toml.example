# Copy this file to .streamlit/secrets.toml for local development.
# Do not commit .streamlit/secrets.toml because it contains private keys.

FRED_API_KEY = "your_fred_api_key"
SBN_YIELD = 0.065

# Optional; without it, Fear & Greed is approximated from VIX.
RAPIDAPI_KEY = "your_rapidapi_key"

# Alternative supported FRED format if you prefer a nested section:
# [fred]
# api_key = "your_fred_api_key"
